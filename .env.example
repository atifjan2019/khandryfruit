# Supabase database: transaction pooler for Vercel runtime, session pooler for
# Prisma migrations. URL-encode special characters in the database password.
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
DATABASE_URL="postgresql://postgres.PROJECT_REF:SUPABASE_DATABASE_PASSWORD@REGION.pooler.supabase.com:6543/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.PROJECT_REF:SUPABASE_DATABASE_PASSWORD@REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Authentication
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-at-least-32-random-characters"
AUTH_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_replace_me"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"

# AWS-compatible storage and transactional email
AWS_REGION="eu-central-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_S3_ENDPOINT=""
AWS_SES_FROM_EMAIL=""

# Public and business configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="de"
ADMIN_EMAIL="orders@example.com"
WHATSAPP_NUMBER="4917621809185"
WHATSAPP_MESSAGE_DE="Hallo, ich habe eine Frage zu Khan Dry Fruit."
WHATSAPP_MESSAGE_EN="Hello, I have a question about Khan Dry Fruit."

# Optional consent-controlled integrations
GOOGLE_ANALYTICS_ID=""
GOOGLE_SITE_VERIFICATION=""
META_PIXEL_ID=""
TIKTOK_PIXEL_ID=""
SENTRY_DSN=""
CRON_SECRET="replace-with-a-random-cron-secret"

# Development seed credentials - never reuse in staging or production
SEED_ADMIN_EMAIL="admin@khandryfruit.local"
SEED_ADMIN_PASSWORD="ChangeMe-Local-Only-2026!"
SEED_CUSTOMER_EMAIL="customer@khandryfruit.local"
SEED_CUSTOMER_PASSWORD="ChangeMe-Local-Only-2026!"
